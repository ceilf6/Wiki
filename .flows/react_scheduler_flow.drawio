<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="React Scheduler Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200"
      pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Nodes -->
        <mxCell id="unstable" value="unstable_scheduleCallback" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="decision" value="是否为延时任务?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="425" y="110" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="pushTimer" value="push(timerQueue, newTask)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="130" width="260" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="requestTimeout" value="requestHostTimeout" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="220" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="handleTimeout" value="handleTimeout" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="310" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="pushTask" value="push(taskQueue, newTask)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="250" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="requestCallback" value="requestHostCallback" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="330" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="schedulePerform" value="schedulePerformWorkUntilDeadline" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="420" width="350" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="perform" value="performWorkUntilDeadline" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="510" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="scheduledHostCallback" value="scheduledHostCallback" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="375" y="600" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="flushWork" value="flushWork" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="690" width="210" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="workLoop" value="workLoop" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="780" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" edge="1" parent="1" source="unstable" target="decision">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" value="Yes" edge="1" parent="1" source="decision" target="pushTimer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="pushTimer" target="requestTimeout">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="requestTimeout" target="handleTimeout">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="handleTimeout" target="requestCallback">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" value="No" edge="1" parent="1" source="decision" target="pushTask">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="pushTask" target="requestCallback">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" edge="1" parent="1" source="requestCallback" target="schedulePerform">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" edge="1" parent="1" source="schedulePerform" target="perform">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e10" edge="1" parent="1" source="perform" target="scheduledHostCallback">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e11" edge="1" parent="1" source="scheduledHostCallback" target="flushWork">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e12" edge="1" parent="1" source="flushWork" target="workLoop">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
