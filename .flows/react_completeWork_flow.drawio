<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="React completeWork Flow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1"
      connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600"
      pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="completeWork" value="completeWork" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="650" y="20" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="byTag" value="根据 wip.tag 区别对待 (以 HostComponent 为例)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="400" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="updateMount" value="update / mount" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="640" y="230" width="240" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="updateHost" value="updateHostComponent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="250" y="400" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="createInstance" value="createInstance (创建 DOM 元素)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1000" y="400" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="appendChildren" value="appendAllChildren (对子节点执行 appendChild)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1000" y="500" width="380" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="finalize" value="finalizeInitialChildren (设置 DOM 属性)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1000" y="600" width="380" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="bubble" value="bubbleProperties (flag 冒泡)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="650" y="750" width="300" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="completeWork" target="byTag">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="byTag" target="updateMount">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" value="update" edge="1" parent="1" source="updateMount" target="updateHost">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" value="mount" edge="1" parent="1" source="updateMount" target="createInstance">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="createInstance" target="appendChildren">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="appendChildren" target="finalize">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="updateHost" target="bubble">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" edge="1" parent="1" source="finalize" target="bubble">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
