#!/bin/sh
# 子模块 push 后，自动同步父仓库 Wiki 的子模块指针并推送
# 为子模块的每一个提交在父仓库中单独生成一条对应 commit（一步一步跟进）
# 通过 core.hooksPath 配置加载，脚本本身受 Wiki 仓库版本控制

set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
. "$SCRIPT_DIR/lib/bootstrap-path.sh"
ensure_lab_tool_path

# 子模块根目录 & 父仓库根目录
SUB_DIR=$(git rev-parse --show-toplevel)
LATEST_MSG=$(git -C "$SUB_DIR" log -1 --pretty=%B)
# 动态定位父仓库，适用于任意深度的子模块
PARENT_DIR=$(git -C "$SUB_DIR" rev-parse --show-superproject-working-tree 2>/dev/null)
if [ -z "$PARENT_DIR" ]; then
  echo "[post-push] ERROR: 无法找到父仓库（非子模块环境）" >&2
  exit 1
fi

# 子模块相对于父仓库的路径，例如 React/Ahooks-source
SUB_REL=$(realpath --relative-to="$PARENT_DIR" "$SUB_DIR" 2>/dev/null \
  || python3 -c "import os; print(os.path.relpath('$SUB_DIR','$PARENT_DIR'))")

echo "[post-push] 同步父仓库 Wiki 子模块指针（逐提交模式）..."

cd "$PARENT_DIR" || exit 1

# 先拉取远端最新，避免 non-fast-forward 推送失败
git pull --no-rebase --no-edit

# 默认把 Wiki 父仓库当前工作区的所有改动一起带上，
# 避免子模块同步时漏掉同批次的父仓库修改。
git add -A

# 父仓库当前记录的子模块指针（旧 SHA）
OLD_SHA=$(git ls-tree HEAD "$SUB_REL" | awk '{print $3}')
# 子模块当前 HEAD（新 SHA）
NEW_SHA=$(git -C "$SUB_DIR" rev-parse HEAD)

if [ "$OLD_SHA" = "$NEW_SHA" ]; then
  if git diff --cached --quiet; then
    echo "[post-push] 父仓库无需更新（指针未变化且工作区无变更）"
    exit 0
  fi
  echo "[post-push] 子模块指针未变化，改为提交 Wiki 工作区改动..."
  COMMITS="$NEW_SHA"
else
  # 某些大体量/高频同步子模块只需要在父仓库记录最终指针，
  # 避免为同一次 push 中的每个子提交都生成一条父仓库提交。
  case "$SUB_REL" in
    "AI/3-Application/Openclaw-source")
      echo "[post-push] $SUB_REL 使用最终指针模式（只提交最新 SHA）..."
      COMMITS="$NEW_SHA"
      ;;
    *)
      # 按时间顺序列出 OLD_SHA..NEW_SHA 之间的每一个提交（从旧到新）
      COMMITS=$(git -C "$SUB_DIR" log --reverse --pretty="%H" "${OLD_SHA}..${NEW_SHA}")
      ;;
  esac
fi

COUNT=0
for SHA in $COMMITS; do
  MSG=$(git -C "$SUB_DIR" log -1 --pretty=%B "$SHA" 2>/dev/null || printf '%s' "$LATEST_MSG")
  # 将父仓库 index 中的子模块指针拨到该 SHA，无需实际 checkout 子模块
  git update-index --cacheinfo "160000,${SHA},${SUB_REL}"
  if git diff --cached --quiet; then
    continue
  fi
  git commit -m "$MSG"
  COUNT=$((COUNT + 1))
  echo "[post-push] [$COUNT] 已提交父仓库：${SHA} - $(echo "$MSG" | head -1)"
done

if [ "$COUNT" -eq 0 ]; then
  echo "[post-push] 父仓库无需更新（没有新的已暂存改动）"
  exit 0
fi

echo "[post-push] 共创建 $COUNT 条父仓库提交，开始推送..."

# 推送，失败则 pull merge 后重试（应对竞态场景），最多 3 次
PUSH_RETRY=3
while [ $PUSH_RETRY -gt 0 ]; do
  if git push; then
    echo "[post-push] 父仓库 Wiki 已同步推送（$COUNT 条提交）"
    break
  fi
  PUSH_RETRY=$((PUSH_RETRY - 1))
  if [ $PUSH_RETRY -eq 0 ]; then
    echo "[post-push] ERROR: 父仓库推送失败（已重试3次），请手动执行: cd $PARENT_DIR && git push" >&2
    exit 1
  fi
  echo "[post-push] 推送冲突，正在重新拉取后重试（剩余 $PUSH_RETRY 次）..."
  git pull --no-rebase --no-edit
done
