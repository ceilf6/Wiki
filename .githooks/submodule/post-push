#!/bin/sh
# 子模块 push 后，自动同步父仓库 Lab 的子模块指针并推送
# 通过 core.hooksPath 配置加载，脚本本身受 Lab 仓库版本控制

set -e

# 获取子模块最新一条 commit 信息
COMMIT_MSG=$(git log -1 --pretty=%B)

# 父仓库根目录：子模块工作目录是 Lab/React/source，往上两级即 Lab
PARENT_DIR=$(cd "$(git rev-parse --show-toplevel)/../.." && pwd)

echo "[post-push] 同步父仓库 Lab 子模块指针..."

cd "$PARENT_DIR" || exit 1

# 先拉取远端最新，避免 non-fast-forward 推送失败（merge 保留历史）
git pull --no-rebase

# 暂存 Lab 中所有变更（包括子模块指针及其他未提交内容）
git add -A

# 检查是否有变更需要提交
if git diff --cached --quiet; then
  echo "[post-push] 父仓库无需更新（指针未变化）"
  exit 0
fi

git commit -m "$COMMIT_MSG"

# 推送，失败则 pull merge 后重试（应对 CI 自动提交等竞态场景），最多 3 次
PUSH_RETRY=3
while [ $PUSH_RETRY -gt 0 ]; do
  if git push; then
    echo "[post-push] 父仓库 Lab 已同步推送，commit: $COMMIT_MSG"
    break
  fi
  PUSH_RETRY=$((PUSH_RETRY - 1))
  if [ $PUSH_RETRY -eq 0 ]; then
    echo "[post-push] ERROR: 父仓库推送失败（已重试3次），请手动执行: cd $PARENT_DIR && git push" >&2
    exit 1
  fi
  echo "[post-push] 推送冲突，正在重新拉取后重试（剩余 $PUSH_RETRY 次）..."
  git pull --no-rebase
done
